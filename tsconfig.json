{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["bun-types"],
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@stark/core": ["./packages/core/src"],
      "@stark/core/*": ["./packages/core/src/*"],
      "@stark/cli": ["./packages/cli/src"],
      "@stark/cli/*": ["./packages/cli/src/*"],
      "@stark/telegram": ["./packages/telegram/src"],
      "@stark/telegram/*": ["./packages/telegram/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
